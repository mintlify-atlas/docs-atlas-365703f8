  "keyFeatures": [
    "High-performance: >1M msgs/sec producer, >3M msgs/sec consumer",
    "Full Exactly-Once Semantics (EOS) with idempotent and transactional producers",
    "High-level balanced KafkaConsumer with consumer group support",
    "Admin client for topic and cluster management",
    "SSL/TLS and SASL authentication (GSSAPI, PLAIN, SCRAM, OAUTHBEARER/OIDC)",
    "Compression support: snappy, gzip, lz4, zstd",
    "C and C++ APIs with guaranteed ABI stability",
    "Statistics metrics via JSON callbacks",
    "Cross-platform: Linux, macOS, Windows, Solaris, FreeBSD, AIX",
    "KIP-848 Next Generation Consumer Group Protocol support"
  ],
  "publicApiSurface": [
    "rd_kafka_new() — Create producer/consumer handle",
    "rd_kafka_destroy() — Destroy client handle",
    "rd_kafka_conf_new() / rd_kafka_conf_set() — Configuration API",
    "rd_kafka_produce() — Produce a message",
    "rd_kafka_flush() — Wait for outstanding messages",
    "rd_kafka_consumer_poll() — Poll for messages",
    "rd_kafka_subscribe() / rd_kafka_assign() — Consumer topic assignment",
    "rd_kafka_consumer_close() — Close consumer",
    "rd_kafka_commit() / rd_kafka_commit_message() — Offset commit",
    "rd_kafka_poll() — Serve delivery report callbacks",
    "rd_kafka_begin_transaction() / rd_kafka_commit_transaction() — Transactions",
    "rd_kafka_admin_*() — Admin operations (CreateTopics, DeleteTopics, etc.)",
    "RdKafka::Producer — C++ Producer class",
    "RdKafka::KafkaConsumer — C++ high-level Consumer class",
    "RdKafka::Conf — C++ configuration class"
  ]
}
